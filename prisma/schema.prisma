generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PURCHASER
  VIEWER
}

enum Marketplace {
  SHOPEE
  TOKOPEDIA
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  PRICE_CHANGED
}

enum PurchaseStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ORDERED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  PRICE_DROP
  STOCK_ALERT
  SUPPLIER_UPDATE
  PROJECT_UPDATE
  SYSTEM
}

enum ExportFormat {
  PDF
  EXCEL
  CSV
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(PURCHASER)
  department    String?
  phone         String?

  accounts       Account[]
  sessions       Session[]
  favorites      Favorite[]
  projects       PurchaseProject[]
  searchHistory  SearchHistory[]
  notifications  Notification[]
  settings       Settings?
  aiAnalyses     AIAnalysis[]
  comparisonHistories ComparisonHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Product {
  id              String        @id @default(cuid())
  externalId      String?
  name            String
  slug            String        @unique
  description     String?       @db.Text
  imageUrl        String?
  images          String[]
  url             String
  marketplace     Marketplace
  category        String?
  subcategory     String?
  brand           String?
  sku             String?

  price           Float
  originalPrice   Float?
  discountPercent Float?
  currency        String        @default("IDR")

  rating          Float?
  reviewCount     Int?
  soldCount       Int?
  stockQuantity   Int?
  minOrder        Int           @default(1)

  isOfficialStore Boolean       @default(false)
  isMall          Boolean       @default(false)
  isStarSeller    Boolean       @default(false)
  freeShipping    Boolean       @default(false)
  hasVoucher      Boolean       @default(false)

  status          ProductStatus @default(ACTIVE)
  lastCheckedAt   DateTime?

  supplierId      String?
  supplier        Supplier?     @relation(fields: [supplierId], references: [id])

  priceHistory    PriceHistory[]
  favoriteOf      Favorite[]
  purchaseItems   PurchaseItem[]
  analyses        AIAnalysis[]
  inGroups        ProductInGroup[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([marketplace, category])
  @@index([price, rating])
  @@index([supplierId])
  @@map("products")
}

model Supplier {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  marketplace     Marketplace
  externalId      String?
  url             String
  imageUrl        String?
  rating          Float?
  reviewCount     Int?
  responseRate    Float?
  responseTime    String?
  shippingSpeed   Float?
  isOfficialStore Boolean   @default(false)
  isMall          Boolean   @default(false)
  isStarSeller    Boolean   @default(false)
  location        String?
  city            String?
  province        String?

  products        Product[]
  groups          ProductGroup[]
  analyses        AIAnalysis[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([marketplace, rating])
  @@map("suppliers")
}

model ProductGroup {
  id          String    @id @default(cuid())
  name        String
  description String?
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  products    ProductInGroup[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("product_groups")
}

model ProductInGroup {
  id          String @id @default(cuid())
  groupId     String
  productId   String
  similarity  Float?

  group       ProductGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([groupId, productId])
  @@map("product_in_groups")
}

model PriceHistory {
  id        String   @id @default(cuid())
  productId String
  price     Float
  stock     Int?

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId, createdAt])
  @@map("price_history")
}

model PurchaseProject {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      PurchaseStatus @default(DRAFT)
  budget      Float?
  currency    String         @default("IDR")
  deadline    DateTime?
  notes       String?        @db.Text
  exportFormat ExportFormat?

  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       PurchaseItem[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId, status])
  @@map("purchase_projects")
}

model PurchaseItem {
  id          String          @id @default(cuid())
  projectId   String
  productId   String?
  productName String
  quantity    Int             @default(1)
  unitPrice   Float
  totalPrice  Float
  notes       String?
  isApproved  Boolean         @default(false)

  project     PurchaseProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  product     Product?        @relation(fields: [productId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("purchase_items")
}

model Favorite {
  id        String  @id @default(cuid())
  userId    String
  productId String
  notes     String?
  tags      String[]

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("favorites")
}

model AIAnalysis {
  id              String   @id @default(cuid())
  type            String
  title           String
  summary         String?  @db.Text
  result          Json
  confidenceScore Float?
  model           String   @default("glm-5.2")

  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@index([userId, type])
  @@map("ai_analyses")
}

model ComparisonHistory {
  id          String @id @default(cuid())
  userId      String
  productIds  String[]
  title       String?
  result      Json?

  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@map("comparison_histories")
}

model SearchHistory {
  id         String    @id @default(cuid())
  userId     String
  query      String
  filters    Json?
  resultCount Int?
  marketplace Marketplace?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("search_history")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  message   String
  read      Boolean          @default(false)
  link      String?

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@map("notifications")
}

model Settings {
  id          String @id @default(cuid())
  userId      String @unique
  theme       String @default("system")
  language    String @default("id")
  currency    String @default("IDR")
  notifications Json @default("{}")

  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}
